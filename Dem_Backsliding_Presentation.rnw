\section{Introduction}


\subsection{Motivation}

\miniframeson
\begin{frame}[c]{``Losers' Consent'': A Weak Assumption}
\begin{columns}[T] % The [T] option aligns column content at the top

    \begin{column}{0.5\textwidth} % Left column and width
        \begin{itemize}
            \item<1-> Political elites in stable democracies typically accept electoral losses.
            \item<2-> However, this pattern has been disrupted: Trump's and Bolsonaro's supporters did not accept their defeat and engaged in violent protests.            
            \item<3-> While research has looked into ``losers' consent,'' focusing on satisfaction, trust, and efficacy.
            \item<4->  The ``{\bf \color{red}losers' consent}'' {\bf \color{red}literature has not studied the propensity to support \underline{anti-systemic protests}}.
        \end{itemize}
    \end{column}

    \begin{column}{0.5\textwidth} % Right column and width
        % Show the first figure only with the first item
        \begin{figure}
            \includegraphics<2,3,4>[scale=0.4]{Brasil_US_storming.jpeg} % Adjust path and size as needed
        \end{figure}
    \end{column}
    
\end{columns}
\end{frame}


\subsection{Our Paper}

\miniframeson
\begin{frame}[c]{Our Contribution}

  \begin{itemize}
    \item {\color{blue}We analyze the level of system support among electoral losers using novel data from a conjoint experiment in Chile (N=\Sexpr{chile.sample.size}) and Estonia (N=\Sexpr{estonia.sample.size})}.

    \item We exploit institutional heterogeneities (presidential v. parliamentary systems).%,which effectively shift the \emph{costs} of losing/winning an election.

    \item We pre-registered the following hypotheses: \href{https://osf.io/u72z4}{\beamergotobutton{\texttt{link}}}
      
    \begin{itemize}
      \item[H1] \only<1>{Electoral {\color{blue}losers} favor candidates endorsing {\color{blue}anti-systemic protests} more than winners.}\only<3>{Electoral losers favor candidates endorsing anti-systemic actions more than winners.}
           \only<2>{\textcolor{amber}{Electoral losers favor candidates endorsing anti-systemic actions more than winners.}}
      \item[H2] \only<1-2>{This tendency is stronger in {\color{blue}presidential} than in parliamentary systems.}
           \only<3>{\textcolor{americanrose}{This tendency is stronger in presidential than in parliamentary systems.}}
    \end{itemize}

\end{itemize}

\end{frame}

\section{Theory}

\subsection{Soc. Movements and Institutional Literature}



\miniframeson
\begin{frame}[c]{Theoretical Background}

  \begin{enumerate}
    \item {\bf Social movements}:

      \begin{itemize}
        
        \item \emph{``Angry'' losers} might be more willing to support anti-systemic politicians.\\ {\tiny{\color{gray}(Bowler, Donovan, and Karp 2007)}}
 
        \item Winners (who draw instrumental benefits from the system) should oppose politicians supporting anti-systemic actions.

        \item[{\color{red}\Pointinghand}] Loser's consent: introduce the case of {\bf violent protests}.\pause
     
      \end{itemize}

  \item {\bf Institutional literature}: institutional setups affect differently the costs of losing an election \tiny{{\color{gray}(Lijphart, 2012)}}.

        \begin{itemize}
        
        \item  {\bf Presidential}: losers have little input outside of the electoral cycle. 

        \item {\bf Parliamentary}: losers’ interests can be represented through a variety of power sharing institutions. 

        \item[{\color{red}\Pointinghand}] Thus, in presidential systems, the stakes are higher, creating more incentives to oppose the government via {\bf violent protests}.
     
      \end{itemize}

\end{enumerate}

\end{frame}



\section{Research Design}

\subsection{Case Selection}

\miniframeson
\begin{frame}[c]{Case Selection}


\begin{columns}

\onslide<1->{
\begin{column}[T]{0.45\textwidth}
    \begin{minipage}[c][.6\textheight][c]{\linewidth}
    \begin{itemize}

        \item Collected novel data from Chile (N=\Sexpr{chile.sample.size}) and Estonia (N=\Sexpr{estonia.sample.size}).

        \item {\bf Most dissimilar cases}: maximize variance regarding government system (Presidential and Parliamentary).

        \item {\bf Most similar cases}: two consolidated Third-wave democracies.
    \end{itemize} 
    \end{minipage}}
\end{column}

\begin{column}[T]{0.65\textwidth}
    \begin{minipage}[c][.6\textheight][c]{1.1\linewidth}
    \centering{\includegraphics<2>[width=1\textwidth]{VD_Chile_Estonia_present_1.pdf}}
    \centering{\includegraphics<3>[width=1\textwidth]{VD_Chile_Estonia_present_2.pdf}}
    \centering{\includegraphics<4>[width=1\textwidth]{VD_Chile_Estonia_present_3.pdf}}
    \end{minipage}
\end{column}

\end{columns}

\end{frame}



\subsection{Experimental Design}

\miniframeson
\begin{frame}[c]{Conjoint Experiment}

  \begin{itemize}
    \item Designed an unconstrained, fully randomized conjoint experiment. 

    \item {\color{blue}We explored if {\bf hypothetical} (conjoint) {\bf candidates} who support violent protests receive different levels of support from {\bf actual winning and losing participants}}.

    %{\tiny\parencite{Hainmueller2014}}.
    \item We depart from standard AMCE analyses {\color{gray}{\tiny\parencite{Hainmueller2014}}} and instead compute {\bf subgroup marginal means} {\color{gray}{\tiny\parencite{Leeper2020a}}}.
    %\item In practice, when using marginal means, there's no need to set a reference category.
    %\item ``In a forced-choice conjoint design, the grand mean is by definition 0.5'' {\scriptsize\parencite[p. 209]{Leeper2020a}}.

  \end{itemize}

\end{frame}


\miniframesoff
\begin{frame}[c]{Attribute Set}

\begin{table}[h]
%\begin{footnotesize}
\scalebox{0.7}{
\begin{tabular}{  c |  p{0.6\linewidth} }
\toprule
\textbf{Dimension} & \textbf{Attribute Set} \\
\midrule
{\only<2,3>{\leavevmode\color{blue}}Gender} & {\only<2>{\leavevmode\color{red}}Male}, {\only<3>{\leavevmode\color{red}}Female}. \\
{\only<4,5,6>{\leavevmode\color{blue}}Age} & {\only<4>{\leavevmode\color{red}}Younger than 35}, {\only<5>{\leavevmode\color{red}}Between 35-50}, {\only<6>{\leavevmode\color{red}}Over 50}. \\
{\only<7,8>{\leavevmode\color{blue}}Protest} & {\only<7>{\leavevmode\color{red}}The candidate OPPOSES anti-government protest that will seek to de-destabilize the current government}, {\only<8>{\leavevmode\color{red}}The candidate SUPPORTS anti-government protest that will seek to de-destabilize the current government} \\
{\only<9,10>{\leavevmode\color{blue}}Pensions} & {\only<9>{\leavevmode\color{red}}The candidate OPPOSES increases in pensions for the elderly}, {\only<10>{\leavevmode\color{red}}The candidate SUPPORTS increases in pensions for the elderly}\\ 
\bottomrule
\end{tabular}}
%\end{footnotesize}
\end{table}
\end{frame}



\miniframesoff
\begin{frame}[c]{Conjoint Experiment: An Hypothetical Example}

\begin{itemize}
  \item Respondents were asked to choose between two options. For {\bf example}:
\end{itemize}

\begin{table}[h]
%\begin{footnotesize}
\scalebox{0.7}{
\begin{tabular}{p{0.5\linewidth} | p{0.5\linewidth}}
\toprule
\textbf{Candidate 1} & \textbf{Candidate 2} \\
\midrule
Female & Female \\
Over 50 & Between 35-50 \\
The candidate OPPOSES anti-government protest that will seek to de-destabilize the current government & The candidate SUPPORTS anti-government protest that will seek to de-destabilize the current government \\
The candidate OPPOSES increases in pensions for the elderly & The candidate OPPOSES increases in pensions for the elderly\\ 
\midrule
\multicolumn{2}{c}{\texttt{Please, choose one candidate}}\\
\bottomrule
\end{tabular}}
%\end{footnotesize}
\end{table}

\begin{itemize}
  \item Respondents repeated this process 8 times.
  \item {\bf \color{blue}Every time, cells change their content at random}.
\end{itemize}

\end{frame}





\subsection{Winning and Losing Statuses}

\miniframeson
\begin{frame}[c]{Winning and Losing Statuses: How we measured them}

  \begin{itemize}
    \item {\only<2>{\leavevmode\color{Red}}{\bf Losers}}/{\only<3>{\leavevmode\color{ForestGreen}}{\bf Winners}}: asked who respondents voted for {\bf in the last (real) election}.

      \begin{itemize}
        \item {\bf Chile}: ``\emph{Which candidate did you vote for in the 2nd round of the December 2021 presidential election?}'' 
        \\ {\only<2>{\leavevmode\color{Red}}\texttt{Kast}}, {\only<3>{\leavevmode\color{ForestGreen}}\texttt{Boric}}, \texttt{Others} {\tiny(\texttt{Blank/Spoiled}, \texttt{I did not vote}, \texttt{Prefer not to say})}.
        \item {\bf Estonia}: ``\emph{Which political party did you vote for in the [March 2023 parliamentary election]?}'' %\\ {\tiny \texttt{List of Estonian political parties that participated in the March 2023 parliamentary election}.}
      \end{itemize}
 
  \end{itemize}

\end{frame}



\section{Results}

\subsection{Subgroup Marginal Means (MM): Estonia}


\miniframeson
\begin{frame}

\begin{columns}

\begin{column}[T]{0.45\textwidth}
    \begin{minipage}[c][.6\textheight][c]{\linewidth}
     {\Large\textbf{Estonia}} % ← bold left-side title
    \begin{itemize}
        \item {\only<2>{\leavevmode\color{Red}}(Hypothetical) Candidates {\bf favoring violent protests} are systematically {\bf supported} by (actual) losers.}

        \item {\only<3>{\leavevmode\color{Red}}{\bf Losers' Effect}: mainly driven by anti-migrant and anti-LGBT extreme right EKRE voters.}

  
        \item {\only<4>{\leavevmode\color{Red}}{\bf Disengaged citizens}: favor candidates proposing violent protests.}    

    \end{itemize} 
    \end{minipage}
\end{column}

\begin{column}[T]{0.65\textwidth}
    \begin{minipage}[c][.6\textheight][c]{1.1\linewidth}
        \begin{center}
          \vspace{0.6cm}\hspace{-0.8cm}\includegraphics[scale=.295, center]{Conjoint_Winner_Loser.pdf}
        \end{center}
    \end{minipage}
\end{column}

\end{columns}

\end{frame}

\subsection{Subgroup Marginal Means (MM): Chile}


\miniframeson
\begin{frame}[c]%{Losers' Consent and Democratic Stability}

\begin{columns}

\begin{column}[T]{0.45\textwidth}
    \begin{minipage}[c][.6\textheight][c]{\linewidth}
         {\Large\textbf{Chile}} % ← bold left-side title

    \begin{itemize}

        \item {\only<2>{\leavevmode\color{Red}}(Hypothetical) Candidates {\bf favoring violent protests} are systematically {\bf rejected} by (actual) winners \emph{and} losers.}

        \item {\only<3>{\leavevmode\color{Red}}{\bf Legacy effects}: results are driven by the legacies of the 2019-20 protests (\emph{`Social Unrest'}).}

        \item {\only<4>{\leavevmode\color{Red}}{\bf Losers (Kast)} show even {\bf stronger disapproval} of violent protests.}



    \end{itemize} 
    \end{minipage}
\end{column}

\begin{column}[T]{0.65\textwidth}
    \begin{minipage}[c][.6\textheight][c]{1.1\linewidth}
        \begin{center}
          \vspace{0.6cm}\hspace{-0.8cm}\includegraphics[scale=.295, center]{Conjoint_Winner_Loser.pdf}
        \end{center}
    \end{minipage}
\end{column}

\end{columns}

\end{frame}


\section{Discussion}


\subsection{Main Takeaways}



\miniframeson
\begin{frame}[c]{Discussion: More Questions Than Answers}
  \begin{itemize}
    \item We hypothesized (and pre-registered) that:
      \begin{enumerate}
          \item[H1] \emph{Electoral losers} were \emph{more} willing to support anti-systemic protests. 
          \item[H2] This effect would be \emph{stronger} in Presidential systems. \\ {\scriptsize{\bf Losses are more catastrophic.}}
      \end{enumerate}
    
    \item While we did not find support in favor of our hypotheses, we still found other interesting results.

    \begin{itemize}
      \item {\bf Chile}: {\color{blue}Extreme-right} supporters (\underline{losers}) are {\color{blue}less} likely to support violent protests.
      \item {\bf Estonia}: {\color{blue}Extreme-right} supporters (\underline{losers}) are {\color{red}more} likely to support violent protests.
    \end{itemize}

    %  \begin{exampleblock}{Motivating Questions for Q\&A}
    %Did we make a mistake to think that, {\bf in Chile (!)}, right-wing losers were going to {\bf protests} (!)? {\bf Let me know what you think}.
    %  \end{exampleblock}




  \end{itemize}
\end{frame}


