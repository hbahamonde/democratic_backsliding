\section{Introducción}

\subsection{Motivación}

\begin{frame}[c]{``Losers' Consent'': A Weak Assumption}
\begin{columns}[T]
    \begin{column}{0.5\textwidth}
        \begin{itemize}
            \item<1-> Las élites políticas en democracias estables típicamente aceptan perder elecciones.
            \item<2-> Sin embargo, este patrón se ha roto: los seguidores de Trump y Bolsonaro no aceptaron sus derrotas y participaron en protestas violentas.
            \item<3-> Aunque se ha estudiado el ``Losers' Consent'', la literatura se ha centrado en satisfacción, confianza y eficacia.
            \item<4-> La literatura sobre {\bf \color{red}``Losers' Consent''} {\bf \color{red}no ha estudiado la propensión a apoyar \underline{protestas anti-sistémicas}}.
        \end{itemize}
    \end{column}
    \begin{column}{0.5\textwidth}
        \begin{figure}
            \includegraphics<2,3,4>[scale=0.4]{Brasil_US_storming.jpeg}
        \end{figure}
    \end{column}
\end{columns}
\end{frame}

\subsection{Nuestro Estudio}

\begin{frame}[c]{Nuestra contribución: Un experimento descriptivo en Chile y un ``shadow case''}
  \begin{itemize}
    \item {\color{blue}Analizamos el apoyo al sistema entre perdedores electorales con datos nuevos de un experimento tipo conjoint en Chile} (N=\Sexpr{chile.sample.size}).
    \item[{\color{red}\Pointinghand}] Utilizamos el caso de Estonia (N=\Sexpr{estonia.sample.size}) como un {\bf ``\emph{shadow case}''} para contrastar con Chile {\color{gray}\footnotesize(Mahoney \& Goertz, 2006)}.
    \item Aprovechamos heterogeneidades institucionales (presidencialismo vs parlamentarismo).
    \item Hipótesis pre-registradas: \href{https://osf.io/u72z4}{\beamergotobutton{\texttt{link}}}
    \begin{itemize}
  \item[H1] 
    \only<1>{Los {\color{blue}perdedores electorales} apoyan más a candidatos que respaldan {\color{blue}protestas anti-sistémicas} que los ganadores.}
    \only<2>{\textcolor{amber}{Los perdedores electorales apoyan más a candidatos que respaldan protestas anti-sistémicas que los ganadores.}}
    \only<3>{Los perdedores electorales apoyan más a candidatos que respaldan acciones anti-sistémicas que los ganadores.}

  \item[H2] 
    \only<1-2>{Esta tendencia es más fuerte en sistemas {\color{blue}presidenciales} que en parlamentarios.}
    \only<3>{\textcolor{americanrose}{Esta tendencia es más fuerte en sistemas {\color{americanrose}presidenciales} que en parlamentarios.}}
\end{itemize}
  \end{itemize}
\end{frame}

\section{Marco Teórico}

\subsection{Literatura de Movimientos Sociales e Instituciones}

\begin{frame}[c]{Marco Teórico}
  \begin{enumerate}
    \item {\bf Movimientos sociales}:
      \begin{itemize}
        \item Los \emph{``angry losers''} podrían estar más dispuestos a apoyar a políticos anti-sistémicos {\tiny{\color{gray}(Bowler, Donovan y Karp 2007)}.}
        \item Los ganadores (que obtienen beneficios del sistema) deberían rechazar a políticos que promueven acciones anti-sistémicas.
        \item[{\color{red}\Pointinghand}] Losers' Consent: introducir el caso de las {\bf protestas violentas}.
      \end{itemize}\pause
    \item {\bf Literatura institucional}: la configuración institucional afecta los costos de perder una elección {\tiny{\color{gray}(Lijphart, 2012)}}.
      \begin{itemize}
        \item {\bf Presidencialismo}: los perdedores tienen poca influencia fuera del ciclo electoral.
        \item {\bf Parlamentarismo}: los perdedores pueden estar representados a través de instituciones de reparto de poder.
        \item[{\color{red}\Pointinghand}] Por lo tanto, en sistemas presidenciales, hay más en juego, y más incentivos para oponerse al gobierno vía {\bf protestas violentas}.
      \end{itemize}
  \end{enumerate}
\end{frame}

\section{Diseño de Investigación}

\subsection{Selección de Casos}

\begin{frame}[c]{Selección de Casos}
\begin{columns}
\begin{column}[T]{0.45\textwidth}
    \begin{minipage}[c][.6\textheight][c]{\linewidth}
    \begin{itemize}
        \item Recolectamos datos originales de Chile (N=\Sexpr{chile.sample.size}) y Estonia (N=\Sexpr{estonia.sample.size}).
        \item {\bf ``Most disimilar cases''}: maximizamos varianza en sistemas de gobierno (presidencial vs parlamentario).
        \item {\bf ``Most similar cases''}: ambas son democracias consolidadas de la tercera ola.
    \end{itemize}
    \end{minipage}
\end{column}

\begin{column}[T]{0.65\textwidth}
    \vbox to 0.6\textheight{\centering
        \only<2>{\includegraphics[width=1\textwidth]{VD_Chile_Estonia_present_1.pdf}}%
        \only<3>{\includegraphics[width=1\textwidth]{VD_Chile_Estonia_present_2.pdf}}%
        \only<4>{\includegraphics[width=1\textwidth]{VD_Chile_Estonia_present_3.pdf}}%
        \vfill
    }
\end{column}
\end{columns}
\end{frame}
\subsection{Diseño Experimental}

\begin{frame}[c]{Experimento tipo Conjoint}
  \begin{itemize}
    \item Diseñamos un experimento tipo conjoint completamente aleatorizado.
    \item {\color{blue}Exploramos si candidatos \textbf{hipotéticos} que apoyan protestas violentas reciben distinto nivel de apoyo según si los encuestados son \textbf{ganadores o perdedores reales}.}
    \item En lugar de usar AMCEs tradicionales {\color{gray}{\tiny\parencite{Hainmueller2014}}}, estimamos \textbf{``marginal means'' por subgrupo} {\color{gray}{\tiny\parencite{Leeper2020a}}}.
  \end{itemize}
\end{frame}

\miniframesoff
\begin{frame}[c]{Atributos del experimento}
\begin{table}[h]
\scalebox{0.7}{
\begin{tabular}{c | p{0.6\linewidth}}
\toprule
\textbf{Dimensión} & \textbf{Atributos} \\
\midrule
{\only<2,3>{\leavevmode\color{blue}}Género} & {\only<2>{\leavevmode\color{red}}Hombre}, {\only<3>{\leavevmode\color{red}}Mujer}. \\
{\only<4,5,6>{\leavevmode\color{blue}}Edad} & {\only<4>{\leavevmode\color{red}}Menor de 35}, {\only<5>{\leavevmode\color{red}}Entre 35 y 50}, {\only<6>{\leavevmode\color{red}}Mayor de 50}. \\
{\only<7,8>{\leavevmode\color{blue}}Protestas} & {\only<7>{\leavevmode\color{red}}El/la candidato/a SE OPONE a protestas anti-gobierno que buscan desestabilizar}, {\only<8>{\leavevmode\color{red}}El/la candidato/a APOYA protestas anti-gobierno que buscan desestabilizar}. \\
{\only<9,10>{\leavevmode\color{blue}}Pensiones} & {\only<9>{\leavevmode\color{red}}El/la candidato/a SE OPONE a aumentar las pensiones}, {\only<10>{\leavevmode\color{red}}El/la candidato/a APOYA aumentar las pensiones}. \\
\bottomrule
\end{tabular}}
\end{table}
\end{frame}

\miniframesoff
\begin{frame}[c]{Ejemplo hipotético}
\begin{itemize}
  \item Participantes eligen entre dos opciones. Por \textbf{ejemplo}:
\end{itemize}
\begin{table}[h]
\scalebox{0.7}{
\begin{tabular}{p{0.5\linewidth} | p{0.5\linewidth}}
\toprule
\textbf{Candidato/a 1} & \textbf{Candidato/a 2} \\
\midrule
Mujer & Mujer \\
Mayor de 50 & Entre 35 y 50 \\
Se opone a protestas violentas & Apoya protestas violentas \\
Se opone a aumentar pensiones & Se opone a aumentar pensiones \\
\midrule
\multicolumn{2}{c}{\texttt{Por favor, elija una opción}} \\
\bottomrule
\end{tabular}}
\end{table}
\begin{itemize}
  \item El proceso se repite 8 veces.
  \item {\bf \color{blue}Cada vez, los atributos cambian aleatoriamente}.
\end{itemize}
\end{frame}

\subsection{Ganadores y Perdedores}

\begin{frame}[c]{Ganadores y Perdedores: ¿Cómo los medimos?}
\begin{itemize}
  \item {\only<2>{\leavevmode\color{Red}}{\bf Perdedores}}/{\only<3>{\leavevmode\color{ForestGreen}}{\bf Ganadores}}: preguntamos por quién votaron en la {\bf última elección real}.
  \begin{itemize}
    \item {\bf Chile}: ``\emph{¿Por qué candidato votaste en la segunda vuelta de la elección presidencial de diciembre de 2021?}'' \\
    {\only<2>{\leavevmode\color{Red}}\texttt{Kast}}, {\only<3>{\leavevmode\color{ForestGreen}}\texttt{Boric}}, \texttt{Otros} {\tiny(\texttt{Blanco/Nulo}, \texttt{No votó}, \texttt{Prefiero no responder})}.
    \item {\bf Estonia}: ``\emph{¿Por qué partido votaste en la elección parlamentaria de marzo de 2023?}''
  \end{itemize}
\end{itemize}
\end{frame}

\section{Resultados}

\miniframeson
\subsection{Chile}

\begin{frame}
\begin{columns}
\begin{column}[T]{0.45\textwidth}
\begin{itemize}
  \item Candidatos hipotéticos que apoyan protestas violentas son sistemáticamente rechazados por ganadores y perdedores.
  \item Efectos de legado: influencia del Estallido Social.
  \item Perdedores (Kast) muestran incluso más desaprobación.
\end{itemize}
\end{column}
\begin{column}[T]{0.65\textwidth}
\includegraphics[scale=.295]{Conjoint_Winner_Loser.pdf}
\end{column}
\end{columns}
\end{frame}

\miniframeson
\subsection{Estonia}

\begin{frame}
\begin{columns}
\begin{column}[T]{0.45\textwidth}
\begin{itemize}
  \item Candidatos hipotéticos que apoyan protestas violentas son apoyados por perdedores.
  \item Efecto de los perdedores: votantes EKRE.
  \item Ciudadanos desvinculados: más favorables a protestas.
\end{itemize}
\end{column}
\begin{column}[T]{0.65\textwidth}
\includegraphics[scale=.295]{Conjoint_Winner_Loser.pdf}
\end{column}
\end{columns}
\end{frame}

\section{Discusi\'on}

\subsection{Discusión} 

\miniframeson
\begin{frame}[c]{Discusión: Más preguntas que respuestas}
\begin{itemize}
  \item H1: Perdedores apoyan más protestas.
  \item H2: Efecto mayor en presidencialismo.
  \item Resultados:
  \begin{itemize}
    \item Chile: derecha radical {\color{red}es menos} propensa a apoyar protestas.
    \item Estonia: derecha radical {\color{red}es más propensa} a apoyar protestas.
  \end{itemize}
\end{itemize}
\end{frame}

\miniframeson
\begin{frame}[c]{¿Un experimento fallido? ¿Metimos la pata?}
\begin{exampleblock}{En cierto sentido, es un experimento fallido:}
¿Nos equivocamos al pensar que en Chile {\bf los perdedores de derecha} (!) iban a protestar?
\end{exampleblock}
\begin{itemize}
  \item ¿Cómo podemos reformular el paper?
  \item Lo presentamos como una señal del legado del Estallido Social.
  \item Enviado a Research \& Politics.
  \item Comentarios bienvenidos.
\end{itemize}
\end{frame}

